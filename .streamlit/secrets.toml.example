# Option A: full URI
MONGO_URI = "mongodb+srv://<db_user>:<db_password>@hikinggeardb.03dkpcs.mongodb.net/?appName=HikingGearDB"

# Option B: split fields (recommended if password has special chars)
# MONGO_HOST = "hikinggeardb.03dkpcs.mongodb.net"
